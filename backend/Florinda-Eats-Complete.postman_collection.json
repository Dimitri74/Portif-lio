  "item": [
    {
      "name": "FASE 1 - Catalogo",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{catalogo_base}}/q/health", "host": ["{{catalogo_base}}"], "path": ["q","health"] }
          }
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{catalogo_base}}/swagger-ui", "host": ["{{catalogo_base}}"], "path": ["swagger-ui"] }
          }
        },
        {
          "name": "Criar Restaurante",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Churrascaria Florinda\",\n  \"descricao\": \"Carnes na brasa\",\n  \"categoria\": \"Churrasco\",\n  \"telefone\": \"88999999999\",\n  \"email\": \"contato@florinda.com\",\n  \"endereco\": {\n    \"logradouro\": \"Rua das Flores\",\n    \"numero\": \"10\",\n    \"bairro\": \"Centro\",\n    \"cidade\": \"Juazeiro do Norte\",\n    \"uf\": \"CE\",\n    \"cep\": \"63000-000\"\n  },\n  \"horarioAbertura\": \"11:00:00\",\n  \"horarioFechamento\": \"23:00:00\"\n}"
            },
            "url": { "raw": "{{catalogo_base}}/v1/restaurantes", "host": ["{{catalogo_base}}"], "path": ["v1","restaurantes"] }
          }
        },
        {
          "name": "Listar Restaurantes",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{catalogo_base}}/v1/restaurantes", "host": ["{{catalogo_base}}"], "path": ["v1","restaurantes"] }
          }
        },
        {
          "name": "Buscar Restaurante por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{catalogo_base}}/v1/restaurantes/{{restaurante_id}}", "host": ["{{catalogo_base}}"], "path": ["v1","restaurantes","{{restaurante_id}}"] }
          }
