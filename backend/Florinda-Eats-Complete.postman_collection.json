{
  "info": {
    "name": "Florinda Eats — Completo (Fases 1-3)",
    "description": "Collection para testar todos os endpoints das Fases 1 (Catalogo), 2 (Pedidos+Pagamentos+Notificacoes) e 3 (IA+MCP)",
