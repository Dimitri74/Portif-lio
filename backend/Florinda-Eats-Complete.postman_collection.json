    { "key": "catalogo_base", "value": "http://localhost:8082" },
    { "key": "pedidos_base", "value": "http://localhost:8080" },
    { "key": "pagamentos_base", "value": "http://localhost:8081" },
    { "key": "notificacoes_base", "value": "http://localhost:8084" },
    { "key": "ia_base", "value": "http://localhost:8083" },
    { "key": "mcp_base", "value": "http://localhost:8085" },
