    { "key": "cardapio_id", "value": "COLE_O_ID_AQUI" },
    { "key": "pedido_id", "value": "COLE_O_ID_AQUI" },
    { "key": "pagamento_id", "value": "COLE_O_ID_AQUI" },
    { "key": "sessao_id", "value": "sessao-postman-01" }
