{
  "info": {
    "name": "Florinda Eats — Agente IA (Fase 3)",
    "description": "Collection para testar o ms-ia-suporte (porta 8083) e mcp-florinda-server (porta 8085)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "ia_base", "value": "http://localhost:8083" },
    { "key": "mcp_base", "value": "http://localhost:8085" },
    { "key": "sessao_id", "value": "sessao-postman-01" },
    { "key": "restaurante_id", "value": "COLE_O_ID_DO_RESTAURANTE_AQUI" },
    { "key": "pedido_id", "value": "COLE_O_ID_DO_PEDIDO_AQUI" }
  ],
  "item": [
    {
      "name": "IA Suporte",
      "item": [
        {
          "name": "Health Check Estendido",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{ia_base}}/v1/ia/health", "host": ["{{ia_base}}"], "path": ["v1","ia","health"] }
          }
        },
        {
          "name": "Health Quarkus",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{ia_base}}/q/health", "host": ["{{ia_base}}"], "path": ["q","health"] }
          }
        },
        {
          "name": "Chat — Pergunta Simples",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pergunta\": \"Qual o prazo de entrega?\",\n  \"sessaoId\": \"{{sessao_id}}\"\n}"
            },
            "url": { "raw": "{{ia_base}}/v1/ia/chat", "host": ["{{ia_base}}"], "path": ["v1","ia","chat"] }
          }
        },
        {
          "name": "Chat — Consultar Status Pedido (MCP Tool)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pergunta\": \"Qual o status do pedido {{pedido_id}}?\",\n  \"sessaoId\": \"{{sessao_id}}\"\n}"
            },
            "url": { "raw": "{{ia_base}}/v1/ia/chat", "host": ["{{ia_base}}"], "path": ["v1","ia","chat"] }
          }
        },
        {
          "name": "Chat — Cancelar Pedido (MCP Tool)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pergunta\": \"Quero cancelar meu pedido {{pedido_id}} porque mudei de ideia.\",\n  \"sessaoId\": \"{{sessao_id}}\"\n}"
            },
            "url": { "raw": "{{ia_base}}/v1/ia/chat", "host": ["{{ia_base}}"], "path": ["v1","ia","chat"] }
          }
        },
        {
          "name": "Chat — Consultar Cardápio (MCP Tool)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pergunta\": \"O que tem no cardápio do restaurante {{restaurante_id}}?\",\n  \"sessaoId\": \"{{sessao_id}}\"\n}"
            },
            "url": { "raw": "{{ia_base}}/v1/ia/chat", "host": ["{{ia_base}}"], "path": ["v1","ia","chat"] }
          }
        },
        {
          "name": "Chat — Multi-turno (Turno 1)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pergunta\": \"Ola, fiz um pedido e quero saber o status.\",\n  \"sessaoId\": \"sessao-multi-01\"\n}"
            },
            "url": { "raw": "{{ia_base}}/v1/ia/chat", "host": ["{{ia_base}}"], "path": ["v1","ia","chat"] }
          }
        },
        {
          "name": "Chat — Multi-turno (Turno 2, mesmo sessaoId)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pergunta\": \"O ID e {{pedido_id}}\",\n  \"sessaoId\": \"sessao-multi-01\"\n}"
            },
            "url": { "raw": "{{ia_base}}/v1/ia/chat", "host": ["{{ia_base}}"], "path": ["v1","ia","chat"] }
          }
        },
        {
          "name": "Ingerir Documento Único (Admin RAG)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conteudo\": \"Qual o prazo de entrega? O prazo médio é de 30 a 60 minutos dependendo da distância e do restaurante.\",\n  \"fonte\": \"faq\",\n  \"fonteId\": \"faq-prazo-01\"\n}"
            },
            "url": { "raw": "{{ia_base}}/v1/ia/admin/ingerir", "host": ["{{ia_base}}"], "path": ["v1","ia","admin","ingerir"] }
          }
        },
        {
          "name": "Ingerir Lote de Documentos (Admin RAG)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"conteudo\": \"Como rastrear meu pedido? Acompanhe em tempo real pelo app na seção Meus Pedidos.\",\n    \"fonte\": \"faq\",\n    \"fonteId\": \"faq-rastreio-01\"\n  },\n  {\n    \"conteudo\": \"Quais formas de pagamento são aceitas? PIX, cartão de crédito e débito.\",\n    \"fonte\": \"faq\",\n    \"fonteId\": \"faq-pagamento-01\"\n  },\n  {\n    \"conteudo\": \"Como entro em contato com o restaurante? Via chat no app ou pelo telefone cadastrado no perfil do restaurante.\",\n    \"fonte\": \"faq\",\n    \"fonteId\": \"faq-contato-01\"\n  }\n]"
            },
            "url": { "raw": "{{ia_base}}/v1/ia/admin/ingerir/lote", "host": ["{{ia_base}}"], "path": ["v1","ia","admin","ingerir","lote"] }
          }
        }
      ]
    },
    {
      "name": "MCP Server",
      "item": [
        {
          "name": "Health MCP Server",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{mcp_base}}/q/health", "host": ["{{mcp_base}}"], "path": ["q","health"] }
          }
        },
        {
          "name": "SSE Stream (MCP endpoint — abrir no browser)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "text/event-stream" }],
            "url": { "raw": "{{mcp_base}}/mcp/sse", "host": ["{{mcp_base}}"], "path": ["mcp","sse"] }
          }
        }
      ]
    },
    {
      "name": "Ollama (local)",
      "item": [
        {
          "name": "Listar Modelos Instalados",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "http://localhost:11434/api/tags", "raw": "http://localhost:11434/api/tags" }
          }
        },
        {
          "name": "Gerar Resposta Direta (teste LLM)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"llama3.2\",\n  \"prompt\": \"Responda em uma linha: o que é comida delivery?\",\n  \"stream\": false\n}"
            },
            "url": { "raw": "http://localhost:11434/api/generate", "raw": "http://localhost:11434/api/generate" }
          }
        }
      ]
    }
  ]
}

